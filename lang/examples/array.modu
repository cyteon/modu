let a = "hello, world";

let array = [a, 1, 1.5, true, null];
print("Array: ", array);

print("First element: ", array[0]);

let length = array.len();
print("Array length: ", length);

for v in array {
    print("v: ", v);
}

array.push("new element");
print("after array.push: ", array);

print("array.pop(): ", array.pop());
print("after array.pop: ", array);

print([2, 3, 1].max());
print([3, 1, 2].min());
print([1, 2, 3].reverse());
print([8, 7, 2, 1, 5, 100, 3, false, "test"].sort());