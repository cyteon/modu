import "std/fs";

fs.mkdir("test_dir");
print(fs.exists("test_dir"));
fs.rmdir("test_dir");
print(fs.exists("test_dir"));

let path = input("file path: ");
let f = fs.open(path, "rw");

print("file ptr: ", f);
let content_write = input("content to write: ");

fs.write(f, content_write);
print(fs.stat(f));
print("file content: ", fs.read(f));

fs.close(f);
print(f);

fs.remove(path);