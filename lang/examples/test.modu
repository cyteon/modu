print("\nloop:");

let i = 0;

loop {
    print("i: ", i);
    i += 1;

    if i == 5 {
        break;
    }
}

print("\nwhile loop:");

i = 0;

while i < 5 {
    print("i: ", i);
    i += 1;
}

print("\nfor loop:");

for n in 0..10 {
    print("n: ", n);

    if n == 5 {
        break;
    } else {
        continue;
    }

    print("uh oh");
}

print("\narrays:");

let arr = [10, 20, 30];
arr[0] = 100;
print(arr);
print(arr[0]);

for v in arr {
    print("v: ", v);
}