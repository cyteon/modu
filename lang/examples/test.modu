
if 1 == 1 {
    print("1 == 1");
}

if 1 == 2 {
    print("1 == 2");
} else {
    print("1 != 2");
}

if false {
    
} else if true {
    print("false is not true");
}

if false {
    print("should not print");
} else if false {
    print("should not print");
} else {
    print("both conditions are false");
}

print("\nloop:");

let i = 0;

loop {
    print("i: ", i);
    i += 1;

    if i == 5 {
        break;
    }
}

print("\nwhile loop:");

i = 0;

while i < 5 {
    print("i: ", i);
    i += 1;
}

print("\nfor loop:");

for n in 0..10 {
    print("n: ", n);

    if n == 5 {
        break;
    } else {
        continue;
    }

    print("uh oh");
}

print("\narrays:");

let arr = [10, 20, 30];
print(arr);

for v in arr {
    print("v: ", v);
}